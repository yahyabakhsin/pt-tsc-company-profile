generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. Model Administrator (Autentikasi Auth.js)
// ------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?   // Hashed password untuk login
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ------------------------------------------------------
// 2. Model Portofolio Proyek
// ------------------------------------------------------
model Project {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  
  // Metadata Dasar
  overview        String    @db.Text
  location        String
  projectYear     Int
  industryType    String
  applicationType String
  projectType     String
  services        String
  
  // Detail Konten
  challenge       String    @db.Text
  solution        String    @db.Text
  result          String    @db.Text
  highlights      String[]  // Disimpan sebagai array of strings
  
  // Media Assets
  thumbnailImage  String    // URL dari Cloudinary
  galleryImages   String[]  // Array URL dari Cloudinary
  
  // Timestamps & Data Protection (Soft Delete)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? // Jika ada isinya, berarti data dihapus (Soft Delete)
}

// ------------------------------------------------------
// 3. Model Partner / Logo Showcase
// ------------------------------------------------------
model Partner {
  id           String    @id @default(cuid())
  name         String
  logoUrl      String    // URL dari Cloudinary
  displayOrder Int       @default(0) // Untuk mengatur urutan tampilan logo
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ------------------------------------------------------
// 4. Model Inbox Form (Contact & Quote)
// ------------------------------------------------------
model ContactMessage {
  id          String    @id @default(cuid())
  fullName    String
  companyName String?
  email       String
  phone       String?
  subject     String
  serviceType String?
  message     String    @db.Text
  createdAt   DateTime  @default(now())
}

model QuoteRequest {
  id              String    @id @default(cuid())
  fullName        String
  companyName     String
  email           String
  phone           String
  projectScope    String    @db.Text // Deskripsi kebutuhan
  createdAt       DateTime  @default(now())
}